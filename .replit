modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/api && node dist/main.js & cd apps/web && npm run dev"
waitForPort = 5000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
JWT_SECRET = "vismed_jwt_secret_replit_2024"
VISMED_API_PORT = "3000"

[deployment]
deploymentTarget = "vm"
run = ["sh", "-c", "cd /home/runner/workspace/apps/api && node dist/main.js & cd /home/runner/workspace/apps/web && npm run start"]
build = ["sh", "-c", "cd /home/runner/workspace/apps/api && npx tsc && npx prisma db push --accept-data-loss && node prisma/seed.js && cd /home/runner/workspace/apps/web && npm run build"]
